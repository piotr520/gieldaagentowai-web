# =============================================================================
# WYMAGANE — bez tych wartości aplikacja nie uruchomi się
# =============================================================================

# PostgreSQL — połączenie z bazą danych (Neon, Supabase lub lokalne Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth — sekret JWT (min. 32 znaki, wygeneruj: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# NextAuth — publiczny adres aplikacji (lokalnie: http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# WYMAGANE dla uruchamiania agentów — bez tego /agents/[slug]/run nie działa
# =============================================================================

# OpenAI — klucz API do modelu gpt-4o-mini
OPENAI_API_KEY="sk-..."

# =============================================================================
# WYMAGANE dla płatności Stripe — bez tego checkout i webhook nie działają
# =============================================================================

# Stripe — tajny klucz API (sk_test_... lub sk_live_...)
STRIPE_SECRET_KEY="sk_test_..."

# Stripe — sekret webhooka (whsec_..., ustawiany w Stripe Dashboard)
STRIPE_WEBHOOK_SECRET="whsec_..."

# =============================================================================
# OPCJONALNE — email (reset hasła, powiadomienia admina)
# Jeśli SMTP_HOST nie jest ustawiony, wysyłka emaili jest po cichu pomijana.
# =============================================================================

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
# Ustaw "true" dla portu 465 (SSL), "false" dla 587 (STARTTLS)
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
# Opcjonalne — nadawca maili (domyślnie: "Giełda Agentów AI <noreply@gieldaagentowai.pl>")
SMTP_FROM="Giełda Agentów AI <noreply@example.com>"
