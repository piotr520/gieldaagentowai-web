generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CREATOR
}

enum AgentStatus {
  DRAFT
  PENDING
  PUBLISHED
  HIDDEN
}

enum PricingType {
  FREE
  ONE_TIME
  SUBSCRIPTION
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(CREATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agents       Agent[]
  agentRuns    AgentRun[]
}

model Agent {
  id                       String      @id @default(cuid())
  slug                     String      @unique
  name                     String
  tagline                  String
  category                 String
  pricingType              PricingType @default(FREE)
  pricingLabel             String
  pricingAmountPln         Int?
  pricingAmountPlnPerMonth Int?
  description              String
  limitationsJson          String
  examplesJson             String
  status                   AgentStatus @default(DRAFT)
  lastUpdated              String
  runsCount                Int         @default(0)

  creatorId                String
  creator                  User        @relation(fields: [creatorId], references: [id])

  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  runs                     AgentRun[]

  @@index([status])
  @@index([category])
}

model AgentRun {
  id         String   @id @default(cuid())
  agentId    String
  userId     String?
  inputJson  String
  outputText String
  createdAt  DateTime @default(now())

  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([userId])
  @@index([createdAt])
}