generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  CREATOR
  ADMIN
}

enum AgentStatus {
  DRAFT
  PENDING
  PUBLISHED
  HIDDEN
  REJECTED
}

enum PricingType {
  FREE
  ONE_TIME
  SUBSCRIPTION
  PAY_PER_USE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agents              Agent[]
  agentRuns           AgentRun[]
  agentAccess         AgentAccess[]
  passwordResetTokens PasswordResetToken[]
  fakePayments        FakePayment[]
}

model Agent {
  id                       String      @id @default(cuid())
  slug                     String      @unique
  name                     String
  tagline                  String
  category                 String
  pricingType              PricingType @default(FREE)
  pricingLabel             String
  pricingAmountPln         Int?
  pricingAmountPlnPerMonth Int?
  pricePerUse              Int?        // PLN per run, only for PAY_PER_USE
  freeRuns                 Int?        // free trial runs (default 3 in code)
  description              String
  limitationsJson          String
  examplesJson             String
  status                   AgentStatus @default(DRAFT)
  rejectionReason          String?
  lastUpdated              String
  runsCount                Int         @default(0)

  creatorId                String
  creator                  User        @relation(fields: [creatorId], references: [id])

  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  runs                     AgentRun[]
  access                   AgentAccess[]
  fakePayments             FakePayment[]
  executions               AgentExecution[]

  @@index([status])
  @@index([category])
}

model AgentRun {
  id         String   @id @default(cuid())
  agentId    String
  userId     String?
  inputJson  String
  outputText String
  createdAt  DateTime @default(now())

  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([userId])
  @@index([createdAt])
}

model AgentAccess {
  id             String   @id @default(cuid())
  userId         String
  agentId        String
  subscriptionId String?  // Stripe subscription ID — set for SUBSCRIPTION pricing
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@index([userId])
  @@index([agentId])
  @@index([subscriptionId])
}

// Fake pay-per-use credits (one record = one purchased run)
model FakePayment {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([userId, agentId])
  @@index([agentId])
}

// Preparation for future automations — NOT active yet
model AgentExecution {
  id         String   @id @default(cuid())
  agentId    String
  type       String   // "manual" | "email" | "webhook" | "scheduled"
  status     String   // "active" | "paused"
  configJson String   // {"email":"..."} | {"url":"..."} | {"cron":"..."}
  createdAt  DateTime @default(now())

  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([type])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}
